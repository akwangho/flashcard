{
  "name": "flashcard-gas",
  "version": "1.3.2",
  "description": "英文單字閃卡 - Google Apps Script 部署工具",
  "private": true,
  "scripts": {
    "setup": "bash deploy.sh setup",
    "push": "bash scripts/run-clasp.sh push",
    "push:watch": "bash scripts/run-clasp.sh push --watch",
    "pull": "bash scripts/run-clasp.sh pull",
    "open": "bash scripts/run-clasp.sh open",
    "open:web": "bash scripts/run-clasp.sh open --webapp",
    "status": "bash scripts/run-clasp.sh status",
    "logs": "bash scripts/run-clasp.sh logs",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "test:file": "jest --bail=1",
    "deploy": "bash scripts/run-clasp.sh push && echo '✅ 推送完成！' && bash scripts/run-clasp.sh open --webapp"
  },
  "devDependencies": {
    "@google/clasp": "^2.4.2",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0"
  }
}
